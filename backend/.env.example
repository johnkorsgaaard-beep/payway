# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/payway?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Firebase
FIREBASE_PROJECT_ID="payway-faroe"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@payway-faroe.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# App
PORT=3000
HOST="0.0.0.0"
NODE_ENV="development"
CORS_ORIGIN="http://localhost:3001"

# Fees (in percentage, e.g., 1.5 = 1.5%)
DEFAULT_TOPUP_FEE_PERCENT=1.0
DEFAULT_MERCHANT_FEE_PERCENT=1.5
P2P_FREE_MONTHLY_LIMIT=10
P2P_FEE_PERCENT=0.5

# Limits (in DKK oere/cents)
DAILY_TRANSACTION_LIMIT=1000000
MONTHLY_TRANSACTION_LIMIT=5000000
MAX_WALLET_BALANCE=5000000
MIN_TOPUP_AMOUNT=5000
MAX_TOPUP_AMOUNT=1000000
